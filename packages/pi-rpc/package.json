{
  "name": "@frostime/pi-rpc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "SPEC.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dir.mjs dist && tsc -p tsconfig.build.json",
    "clean": "node ../../scripts/clean-dir.mjs dist coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "vitest": "^4.1.10"
  }
}
