{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node",
      "vscode",
      "vitest/globals",
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "$shared/*": [
        "src/shared/*"
      ],
      "$webview/*": [
        "src/webview/*"
      ],
      "@frostime/pi-rpc": [
        "../../packages/pi-rpc/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "test/**/*.ts",
    "vite.config.ts"
  ]
}
